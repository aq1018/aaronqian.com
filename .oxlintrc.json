{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".astro/",
    ".husky/",
    ".playwright-mcp/",
    ".wrangler/",
    "dist/",
    "node_modules/",
    "public/"
  ],
  "plugins": ["eslint", "unicorn", "typescript", "oxc", "import", "jsx-a11y", "node", "promise"],
  "env": {
    "browser": true,
    "node": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "off",
    "perf": "error",
    "style": "off",
    "nursery": "off"
  },
  "rules": {
    "eslint/eqeqeq": ["error", "always", { "null": "never" }],
    "eslint/no-duplicate-imports": ["error", { "allowSeparateTypeImports": true }],
    "unicorn/no-null": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/consistent-function-scoping": "off",
    "import/no-unassigned-import": "off",
    "no-unassigned-import": "off"
  },
  "globals": {
    "Astro": "readonly"
  },
  "overrides": [
    {
      "files": ["**/*.test.{ts,js}"],
      "plugins": ["vitest"],
      "rules": {
        "no-await-in-loop": "off",
        "eslint/no-await-in-loop": "off"
      },
      "globals": {
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "expectTypeOf": "readonly",
        "vi": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly"
      }
    }
  ]
}
